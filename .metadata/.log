import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStreamReader;
import java.util.StringTokenizer;

public class Solution {
	private static class Point {
		int row;
		int col;
		public Point() {
			super();
			// TODO Auto-generated constructor stub
		}
		public Point(int row, int col) {
			super();
			this.row = row;
			this.col = col;
		}
		public int getRow() {
			return row;
		}
		public void setRow(int row) {
			this.row = row;
		}
		public int getCol() {
			return col;
		}
		public void setCol(int col) {
			this.col = col;
		}
		@Override
		public String toString() {
			return "Point [row=" + row + ", col=" + col + "]";
		}
		
		
	}
	
	private static int T, N, M, E, result;
	private static int[][] map;
	
	private static Point[] exitLocation = new Point[2];
	private static int[][] exitResult;
	public static void main(String[] args) throws NumberFormatException, IOException {
		BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
		StringTokenizer st;
		T = Integer.parseInt(br.readLine());
		
		for(int testCase = 1; testCase <= T; testCase++) {
			int exitCount = 0;
			N = Integer.parseInt(br.readLine());
			exitResult = new int[2][N];
			for(int i = 0; i < N; i++) {
				st = new StringTokenizer(br.readLine(), " ");
				for(int j = 0; j < N; j++) {
					map[i][j] = Integer.parseInt(st.nextToken());
					if(map[i][j] == 2) {
						exitLocation[exitCount++] = new Point(i, j);
					}
				}
			}
			for(int i = 0; i < N; i++) {
				for(int j = 0; j < N; j++) {
					if(map[i][j] == 1) {
						moveTime(i, j);
					}
				}
			}
			
			System.out.println("#" + testCase + result);
		}
	}
	
	/* 각 사람들의 최적의 비상구에 걸리는 이동 시간 */
	private static void moveTime(int r, int c) {
		Point man = new Point(r, c);
		
		int E1 = calculating(man, exitLocation[0]);
		int E2 = calculating(man, exitLocation[1]);
		
		(E1 < E2)
		
	}
	
	private static int calculating(Point M, Point E) {
		int absR = Math.abs(M.row - E.row);
		int absC = Math.abs(M.col - E.col);
		return (absR+absC);
	}
	
	private static void bfs(int i, int j) {
		private boolean[][] visited = new visited[N][N];
	}
	
	private static boolean isLineOut(int r, int c) {
		if(r<0 || c<0 || r>=N || c>=N) {
			return true;
		}
		return false;
	}
}

